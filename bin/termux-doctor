#!/data/data/com.termux/files/usr/bin/bash
# Termux-Doctor: Main Entrypoint

# Resolve absolute project directory
BASE_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Load libraries
. "$BASE_DIR/lib/branding.sh"
. "$BASE_DIR/lib/utils.sh"

# Load modules
. "$BASE_DIR/modules/environment.sh"
. "$BASE_DIR/modules/storage.sh"
. "$BASE_DIR/modules/network.sh"
. "$BASE_DIR/modules/packages.sh"
. "$BASE_DIR/modules/system.sh"

run_all_checks() {
    show_banner
    log_header
    echo

    log_info "Running environment checks..."
    check_environment
    echo

    log_info "Running storage checks..."
    check_storage
    echo

    log_info "Running network checks..."
    check_network
    echo

    log_info "Running package checks..."
    check_packages
    echo

    log_info "Running system checks..."
    check_system
    echo

    log_success "All checks completed."
}

run_all_checks
